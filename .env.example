# ARAG Environment Configuration
# Copy this file to .env and fill in your values

# Required: LLM API settings
ARAG_API_KEY=your-api-key-here
ARAG_BASE_URL=https://api.openai.com/v1
ARAG_MODEL=gpt-4o-mini

# Optional: HTTP proxy (if needed)
# HTTP_PROXY=http://proxy:port
# HTTPS_PROXY=http://proxy:port

# Optional: CUDA device selection
# CUDA_VISIBLE_DEVICES=0
